{
  "command": "oauth2 client extension update",
  "description": "Update extension data (managers) for an OAuth2 client",
  "parameters": [
    {
      "name": "client-id",
      "type": "string",
      "required": true,
      "description": "OAuth2 client ID"
    },
    {
      "name": "managers",
      "type": "array",
      "required": false,
      "description": "Manager user IDs (comma-separated or JSON array)",
      "notes": "bindedTreasury cannot be changed"
    }
  ],
  "validation_rules": [
    "Only the client owner can update extension",
    "bindedTreasury cannot be modified"
  ],
  "errors": [
    { "code": "EOAUTHCLIENT008", "description": "Not authenticated", "remediation": "Run 'xion-toolkit auth login' first" },
    { "code": "EOAUTHCLIENT010", "description": "Insufficient scope for MGR API", "remediation": "Re-authorize with xion:mgr:write scope" },
    { "code": "EOAUTHCLIENT011", "description": "Not the client owner", "remediation": "Only the client owner can update extension" },
    { "code": "EOAUTHCLIENT012", "description": "Client not found", "remediation": "Check the client ID and try again" }
  ],
  "examples": [
    {
      "description": "Update client managers",
      "params": {
        "client-id": "client_abc123",
        "managers": "user_456,user_789"
      }
    }
  ]
}
