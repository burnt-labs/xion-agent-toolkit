{
  "command": "oauth2 client get",
  "description": "Get details of a specific OAuth2 client",
  "parameters": [
    {
      "name": "client-id",
      "type": "string",
      "required": true,
      "description": "OAuth2 client ID"
    }
  ],
  "errors": [
    { "code": "EOAUTHCLIENT008", "description": "Not authenticated", "remediation": "Run 'xion-toolkit auth login' first" },
    { "code": "EOAUTHCLIENT010", "description": "Insufficient scope for MGR API", "remediation": "Re-authorize with xion:mgr:read scope" },
    { "code": "EOAUTHCLIENT012", "description": "Client not found", "remediation": "Check the client ID and try again" }
  ],
  "examples": [
    {
      "description": "Get client details",
      "params": {
        "client-id": "client_abc123"
      }
    }
  ]
}
