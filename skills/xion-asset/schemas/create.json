{
  "command": "create",
  "description": "Create a new NFT collection",
  "parameters": [
    {
      "name": "type",
      "type": "enum",
      "required": false,
      "enum": ["cw721-base", "cw721-metadata-onchain", "cw721-expiration", "cw721-non-transferable", "cw2981-royalties"],
      "default": "cw721-base",
      "description": "NFT contract type"
    },
    {
      "name": "name",
      "type": "string",
      "required": true,
      "description": "Collection name"
    },
    {
      "name": "symbol",
      "type": "string",
      "required": true,
      "description": "Collection symbol (e.g., NFT)"
    },
    {
      "name": "minter",
      "type": "string",
      "required": false,
      "format": "xion-address",
      "description": "Minter address (defaults to creator)"
    },
    {
      "name": "salt",
      "type": "string",
      "required": false,
      "description": "Unique salt for predictable address (use with predict command)"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "prerequisites": [
    "Must be authenticated (use xion-oauth2 skill first)"
  ],
  "errors": [
    {
      "code": "NOT_AUTHENTICATED",
      "description": "User is not logged in",
      "remediation": "Run 'xion-toolkit auth login' first"
    },
    {
      "code": "INVALID_ARGS",
      "description": "Missing required parameters (name and symbol required)",
      "remediation": "Provide both --name and --symbol parameters"
    },
    {
      "code": "INVALID_MINTER_ADDRESS",
      "description": "Invalid minter address format",
      "remediation": "Provide a valid Xion address starting with 'xion1'"
    },
    {
      "code": "INSTANTIATE_FAILED",
      "description": "Failed to instantiate NFT contract",
      "remediation": "Check logs for detailed error message"
    },
    {
      "code": "DUPLICATE_SALT",
      "description": "A contract with this salt already exists",
      "remediation": "Use a different salt value"
    },
    {
      "code": "NETWORK_ERROR",
      "description": "Failed to connect to network",
      "remediation": "Check network connectivity and try again"
    }
  ],
  "examples": [
    {
      "description": "Create standard NFT collection",
      "params": {
        "type": "cw721-base",
        "name": "My Collection",
        "symbol": "NFT"
      }
    },
    {
      "description": "Create collection with predictable address",
      "params": {
        "type": "cw721-base",
        "name": "My Collection",
        "symbol": "NFT",
        "salt": "my-unique-salt-123"
      }
    }
  ]
}