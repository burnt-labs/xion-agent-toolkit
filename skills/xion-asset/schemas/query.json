{
  "command": "query",
  "description": "Query NFT contract",
  "parameters": [
    {
      "name": "contract",
      "type": "string",
      "required": true,
      "format": "xion-address",
      "description": "NFT contract address"
    },
    {
      "name": "msg",
      "type": "json",
      "required": true,
      "description": "Query message as JSON string"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "common_queries": [
    {
      "name": "nft_info",
      "msg": {"nft_info": {"token_id": "1"}},
      "description": "Get NFT info for a token"
    },
    {
      "name": "all_tokens",
      "msg": {"all_tokens": {}},
      "description": "Get all token IDs"
    },
    {
      "name": "owner_of",
      "msg": {"owner_of": {"token_id": "1"}},
      "description": "Get owner of a token"
    },
    {
      "name": "contract_info",
      "msg": {"contract_info": {}},
      "description": "Get contract info"
    }
  ],
  "errors": [
    {
      "code": "NOT_AUTHENTICATED",
      "description": "User is not logged in",
      "remediation": "Run 'xion-toolkit auth login' first"
    },
    {
      "code": "INVALID_ARGS",
      "description": "Missing required parameters (contract and msg required)",
      "remediation": "Provide both --contract and --msg parameters"
    },
    {
      "code": "INVALID_CONTRACT_ADDRESS",
      "description": "Invalid contract address format",
      "remediation": "Provide a valid Xion address starting with 'xion1'"
    },
    {
      "code": "INVALID_QUERY_MSG",
      "description": "Invalid query message format",
      "remediation": "Provide valid JSON query message"
    },
    {
      "code": "CONTRACT_NOT_FOUND",
      "description": "Contract not found at the specified address",
      "remediation": "Verify the address is correct"
    },
    {
      "code": "TOKEN_NOT_FOUND",
      "description": "Token not found",
      "remediation": "Verify the token ID exists"
    },
    {
      "code": "QUERY_FAILED",
      "description": "Failed to query contract",
      "remediation": "Check logs for detailed error message"
    },
    {
      "code": "NETWORK_ERROR",
      "description": "Failed to connect to network",
      "remediation": "Check network connectivity and try again"
    }
  ],
  "examples": [
    {
      "description": "Get NFT info",
      "params": {
        "contract": "xion1abc...",
        "msg": "{\"nft_info\": {\"token_id\": \"1\"}}"
      }
    },
    {
      "description": "Get all tokens",
      "params": {
        "contract": "xion1abc...",
        "msg": "{\"all_tokens\": {}}"
      }
    }
  ]
}