{
  "command": "fee-config set",
  "description": "Set fee allowance for a Treasury",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "required": true,
      "format": "xion-address",
      "description": "Treasury contract address"
    },
    {
      "name": "config",
      "type": "file",
      "required": true,
      "description": "JSON configuration file with fee allowance settings"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "config_schema": {
    "basic": {
      "spend_limit": "string (required) - e.g., '1000000uxion'",
      "description": "string (optional) - fee allowance description"
    },
    "periodic": {
      "basic_spend_limit": "string (required) - overall spend limit",
      "period_seconds": "integer (required) - period duration in seconds",
      "period_spend_limit": "string (required) - spend limit per period",
      "description": "string (optional) - fee allowance description"
    }
  },
  "errors": [
    {
      "code": "NOT_AUTHENTICATED",
      "description": "User is not logged in",
      "remediation": "Run 'xion-toolkit auth login' first"
    },
    {
      "code": "INVALID_ADDRESS",
      "description": "Invalid treasury address format",
      "remediation": "Provide a valid Xion address starting with 'xion1'"
    },
    {
      "code": "INVALID_ARGS",
      "description": "Missing required parameter: config",
      "remediation": "Provide --config parameter with path to JSON file"
    },
    {
      "code": "INVALID_CONFIG",
      "description": "Config file is not valid JSON or missing required fields",
      "remediation": "Check config file format matches the schema"
    },
    {
      "code": "CONFIG_FILE_NOT_FOUND",
      "description": "Config file not found",
      "remediation": "Verify the file path is correct"
    },
    {
      "code": "SET_FEE_CONFIG_FAILED",
      "description": "Failed to set fee configuration",
      "remediation": "Check logs for detailed error message"
    },
    {
      "code": "NETWORK_ERROR",
      "description": "Failed to connect to network",
      "remediation": "Check network connectivity and try again"
    }
  ],
  "examples": [
    {
      "description": "Set basic fee allowance",
      "params": {
        "address": "xion1abc...",
        "config": "fee-config.json"
      },
      "config_content": {
        "basic": {
          "spend_limit": "1000000uxion",
          "description": "Basic fee allowance"
        }
      }
    },
    {
      "description": "Set periodic fee allowance (daily)",
      "params": {
        "address": "xion1abc...",
        "config": "fee-config.json"
      },
      "config_content": {
        "periodic": {
          "basic_spend_limit": "10000000uxion",
          "period_seconds": 86400,
          "period_spend_limit": "1000000uxion",
          "description": "Daily allowance"
        }
      }
    }
  ]
}