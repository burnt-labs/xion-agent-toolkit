{
  "command": "import",
  "description": "Import configuration to a Treasury",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "required": true,
      "format": "xion-address",
      "description": "Treasury contract address"
    },
    {
      "name": "from-file",
      "type": "file",
      "required": true,
      "description": "Path to JSON configuration file"
    },
    {
      "name": "dry-run",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Preview actions without executing"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "notes": [
    "Use --dry-run to preview changes before executing",
    "Configuration file should be generated by export command"
  ],
  "examples": [
    {
      "description": "Preview import (dry run)",
      "params": {
        "address": "xion1abc...",
        "from-file": "treasury-backup.json",
        "dry-run": true
      }
    },
    {
      "description": "Execute import",
      "params": {
        "address": "xion1abc...",
        "from-file": "treasury-backup.json"
      }
    }
  ]
}