{
  "command": "query",
  "description": "Query Treasury details",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "required": true,
      "format": "xion-address",
      "description": "Treasury contract address"
    },
    {
      "name": "include-grants",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Include Authz grant information"
    },
    {
      "name": "include-fee",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Include Fee grant information"
    },
    {
      "name": "no-cache",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Bypass cache and fetch fresh data"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "errors": [
    {
      "code": "NOT_AUTHENTICATED",
      "description": "User is not logged in",
      "remediation": "Run 'xion-toolkit auth login' first"
    },
    {
      "code": "INVALID_ADDRESS",
      "description": "Invalid treasury address format",
      "remediation": "Provide a valid Xion address starting with 'xion1'"
    },
    {
      "code": "TREASURY_NOT_FOUND",
      "description": "Treasury contract not found at the specified address",
      "remediation": "Verify the address is correct and the contract exists"
    },
    {
      "code": "QUERY_FAILED",
      "description": "Failed to query treasury information",
      "remediation": "Check network connectivity and try again"
    },
    {
      "code": "NETWORK_ERROR",
      "description": "Failed to connect to network",
      "remediation": "Check network connectivity and try again"
    }
  ],
  "examples": [
    {
      "description": "Query treasury basic info",
      "params": {
        "address": "xion1abc..."
      }
    },
    {
      "description": "Query treasury with grants and fee info",
      "params": {
        "address": "xion1abc...",
        "include-grants": true,
        "include-fee": true
      }
    }
  ]
}