{
  "command": "withdraw",
  "description": "Withdraw tokens from a Treasury",
  "parameters": [
    {
      "name": "address",
      "type": "string",
      "required": true,
      "format": "xion-address",
      "description": "Treasury contract address"
    },
    {
      "name": "amount",
      "type": "string",
      "required": true,
      "format": "coin",
      "description": "Amount to withdraw with denomination (e.g., 1000000uxion)"
    },
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to use"
    }
  ],
  "notes": [
    "Funds are withdrawn to the admin account",
    "1 XION = 1,000,000 uxion"
  ],
  "errors": [
    {
      "code": "NOT_AUTHENTICATED",
      "description": "User is not logged in",
      "remediation": "Run 'xion-toolkit auth login' first"
    },
    {
      "code": "INVALID_ADDRESS",
      "description": "Invalid treasury address format",
      "remediation": "Provide a valid Xion address starting with 'xion1'"
    },
    {
      "code": "INVALID_AMOUNT",
      "description": "Invalid amount format",
      "remediation": "Use format like '1000000uxion'"
    },
    {
      "code": "INSUFFICIENT_TREASURY_BALANCE",
      "description": "Treasury has insufficient balance",
      "remediation": "Check treasury balance and reduce withdrawal amount"
    },
    {
      "code": "NOT_ADMIN",
      "description": "Only treasury admin can withdraw",
      "remediation": "Use the admin account to withdraw"
    },
    {
      "code": "WITHDRAW_FAILED",
      "description": "Failed to withdraw from treasury",
      "remediation": "Check logs for detailed error message"
    },
    {
      "code": "NETWORK_ERROR",
      "description": "Failed to connect to network",
      "remediation": "Check network connectivity and try again"
    }
  ],
  "examples": [
    {
      "description": "Withdraw 0.5 XION from treasury",
      "params": {
        "address": "xion1abc...",
        "amount": "500000uxion"
      }
    }
  ]
}