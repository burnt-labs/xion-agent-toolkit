{
  "command": "logout",
  "description": "Clear stored credentials for a network",
  "parameters": [
    {
      "name": "network",
      "type": "enum",
      "required": false,
      "enum": ["local", "testnet", "mainnet"],
      "default": "testnet",
      "description": "Network to logout from"
    }
  ],
  "notes": [
    "This removes stored credentials from the keyring",
    "You will need to re-authenticate after logout"
  ],
  "output_includes": [
    "success: boolean",
    "message: string"
  ],
  "examples": [
    {
      "description": "Logout from testnet",
      "params": {}
    },
    {
      "description": "Logout from mainnet",
      "params": {
        "network": "mainnet"
      }
    }
  ]
}